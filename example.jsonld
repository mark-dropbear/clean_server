{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": "list-work-001",
  "name": "Work Tasks",
  "description": "Daily office responsibilities",
  "itemListElement": [
    {
      "@type": "ListItem",
      "item": {
        "@type": "Action",
        "@id": "task-email-001",
        "name": "Process Inbox",
        "description": "Clear all pending emails from the morning",
        "actionStatus": "https://schema.org/CompletedActionStatus"
      }
    },
    {
      "@type": "ListItem",
      "item": {
        "@type": "Action",
        "@id": "task-report-002",
        "name": "Weekly Report",
        "description": "Draft and send the project status report",
        "actionStatus": "https://schema.org/ActiveActionStatus"
      }
    }
  ]
}
