<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hello {{name}}</title>
    {{> csrf }}
    {{> importmap }}
    <script type="module">
        import 'frontend';
        import 'frontend/pages/home.js';
    </script>
  </head>
  <body data-js="false">
    <app-container>
      <home-page>
        <div class="container">
          <h1>Hello, {{name}}!</h1>
          <p>This page is rendered using server-side Mustache templates.</p>
          <p>The time is <span id="time"></span>.</p>
        </div>
      </home-page>
    </app-container>
  </body>
</html>
